# XActions LAN MCP service configuration
# Copy to .env.mcp and fill the two secrets below.

# HTTP MCP transport for LAN clients.
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
PORT=3344

# Local XActions backend. Puppeteer browser actions are serialized so multiple
# MCP clients can share one browser safely.
XACTIONS_MODE=local
XACTIONS_SERIALIZE_LOCAL_TOOLS=true
XACTIONS_LOCAL_TOOL_TIMEOUT_MS=60000
XACTIONS_PREWARM_BROWSER=true
XACTIONS_BROWSER_IDLE_MS=0

# Protect the /mcp endpoint. Generate with: openssl rand -hex 32
XACTIONS_MCP_BEARER_TOKEN=

# X auth_token cookie used by the browser on this LAN host.
XACTIONS_SESSION_COOKIE=

# Optional: set this explicitly on Linux/ARM hosts if Puppeteer's bundled Chrome
# cannot run. `npm run mcp:lan` also tries to auto-detect common Chromium paths.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional: use a persistent Chrome profile directory on this machine.
# XACTIONS_PUPPETEER_USER_DATA_DIR=/absolute/path/to/xactions-puppeteer-profile

# Optional: set only if you intentionally want x402 pay-per-request gating.
# X402_PAY_TO_ADDRESS=
